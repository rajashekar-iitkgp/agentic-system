# --- Google Gemini ---
# Your free Google Gemini API key
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# --- Pinecone Vector Database ---
# Your Pinecone API key and environment. Required for the dynamic Tool Registry.
PINECONE_API_KEY="pc-your-pinecone-api-key-here"
PINECONE_ENVIRONMENT="us-east-1"
PINECONE_INDEX_NAME="tool-registry"

# --- LangSmith Observability (Optional but recommended) ---
# Used for tracing agent execution, tool selection accuracy, and debugging.
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_API_KEY="lsv2_your_langsmith_api_key_here"
LANGCHAIN_PROJECT="scalable_agent_system"

# --- API Settings ---
PROJECT_NAME="Scalable Agentic API"
DEBUG="True"

# --- Infrastructure ---
REDIS_URL="redis://localhost:6379/0"
DATABASE_URL="postgresql+psycopg2://postgres:postgres@localhost:5432/agent_db"

# --- PayPal Credentials ---
PAYPAL_CLIENT_ID="your_client_id"
PAYPAL_CLIENT_SECRET="your_client_secret"
PAYPAL_MODE="sandbox"
